generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Player {
  id            String     @id @default(cuid())
  username      String     @unique
  passwordHash  String  @default("")
  corporation   String
  theme            String  @default("dracula")
  font             String  @default("sans")
  osNotifications  Boolean @default(true)
  showInventory  Boolean @default(true)
  showListings   Boolean @default(true)
  showArchived   Boolean @default(false)
  showPreferences Boolean @default(false)
  discordUsername  String?
  shareFormat     String   @default("{typeLine}{descriptionLine}{offeringLine}{wantingLine}{urlLine}")
  shareLabelOffer String   @default("Offering")
  shareLabelWant  String   @default("Wanting")
  createdAt        DateTime @default(now())
  updatedAt     DateTime   @updatedAt
  artifacts     Artifact[]
  listings      Listing[]
  preference    Preference?
  notifications Notification[]
  sessions      Session[]
  interests     Interest[]
  tradesAsLister Trade[] @relation("TradesAsLister")
  tradesAsTrader Trade[] @relation("TradesAsTrader")
}

model Session {
  id        String   @id @default(cuid())
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([playerId])
}

model Preference {
  id                String               @id @default(cuid())
  playerId          String               @unique
  player            Player               @relation(fields: [playerId], references: [id], onDelete: Cascade)
  categoryThresholds PreferenceCategory[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

model PreferenceCategory {
  id            String     @id @default(cuid())
  preferenceId  String
  preference    Preference @relation(fields: [preferenceId], references: [id], onDelete: Cascade)
  category      ArtifactCategory
  minBonusPct   Float      @default(0)
  minLevel      Int        @default(3)

  @@unique([preferenceId, category])
  @@index([preferenceId])
}

model Notification {
  id        String           @id @default(cuid())
  playerId  String
  player    Player           @relation(fields: [playerId], references: [id], onDelete: Cascade)
  listingId String?
  listing   Listing?         @relation(fields: [listingId], references: [id], onDelete: Cascade)
  tradeId   String?
  trade     Trade?           @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  type      NotificationType @default(GENERAL)
  message   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([playerId])
  @@index([read])
  @@index([tradeId])
}

enum NotificationType {
  GENERAL
  INTEREST_EXPRESSED
  INTEREST_ACCEPTED
  TRADE_CONFIRMATION_NEEDED
  TRADE_CONFIRMED
  TRADE_COMPLETED
  TRADE_CANCELLED
}

model Artifact {
  id               String            @id @default(cuid())
  category         ArtifactCategory
  bonusPct         Float
  level            Int
  playerId         String
  player           Player            @relation(fields: [playerId], references: [id], onDelete: Cascade)
  listingArtifacts ListingArtifact[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  archived         Boolean           @default(false)
  archivedAt       DateTime?
  archiveReason    ArtifactArchiveStatus?
  archiveListingId String?

  @@index([playerId])
  @@index([category])
  @@index([archived])
}

enum ArtifactArchiveStatus {
  TRADED
  EXPIRED
  DELISTED
  DELETED
}

enum ArtifactCategory {
  COMBAT
  TRANSPORT
  MINING
  DRONE
  WEAPON
  SHIELD
}

model Listing {
  id               String            @id @default(cuid())
  description      String?
  playerId         String
  player           Player            @relation(fields: [playerId], references: [id], onDelete: Cascade)
  status           ListingStatus     @default(ACTIVE)
  priceType        PriceType         @default(FREE)
  donationAmount   Float?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  expiresAt        DateTime
  archivedAt       DateTime?
  listingArtifacts ListingArtifact[]
  notifications    Notification[]
  interests        Interest[]
  trades            Trade[]

  @@index([playerId])
  @@index([status])
  @@index([priceType])
  @@index([expiresAt])
}

enum PriceType {
  FREE
  DONATION
  TRADE
}

model ListingArtifact {
  id          String        @id @default(cuid())
  listingId   String
  listing     Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  artifactId  String
  artifact    Artifact      @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  role        ArtifactRole

  @@unique([listingId, artifactId])
  @@index([listingId])
  @@index([artifactId])
}

enum ListingStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  ARCHIVED
}

model Interest {
  id          String   @id @default(cuid())
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  playerId    String
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  message     String?
  status      InterestStatus @default(PENDING)
  createdAt   DateTime @default(now())
  interestArtifacts InterestArtifact[]

  @@index([listingId])
  @@index([playerId])
  @@unique([listingId, playerId])
}

model Trade {
  id              String        @id @default(cuid())
  listingId       String
  listing         Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listerId        String
  lister          Player        @relation("TradesAsLister", fields: [listerId], references: [id], onDelete: Cascade)
  traderId        String
  trader          Player        @relation("TradesAsTrader", fields: [traderId], references: [id], onDelete: Cascade)
  interestId      String?
  status          TradeStatus   @default(PENDING)
  completedAt     DateTime?
  createdAt       DateTime      @default(now())
  tradeArtifacts  TradeArtifact[]
  notifications    Notification[]

  @@index([listerId])
  @@index([traderId])
  @@index([status])
}

model TradeArtifact {
  id          String            @id @default(cuid())
  tradeId     String
  trade       Trade             @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  artifactId  String
  category    ArtifactCategory
  bonusPct    Float
  level       Int
  fromPlayerId String
  toPlayerId   String
  role        TradeArtifactRole

  @@index([tradeId])
  @@index([fromPlayerId])
  @@index([toPlayerId])
}

enum TradeArtifactRole {
  GIVEN
  RECEIVED
}

enum TradeStatus {
  PENDING
  LISTER_CONFIRMED
  TRADER_CONFIRMED
  COMPLETED
  CANCELLED
}

model InterestArtifact {
  id          String          @id @default(cuid())
  interestId  String
  interest    Interest        @relation(fields: [interestId], references: [id], onDelete: Cascade)
  artifactId  String
  role        InterestArtifactRole

  @@index([interestId])
  @@index([artifactId])
  @@unique([interestId, artifactId, role])
}

enum InterestArtifactRole {
  INTERESTED_IN
  OFFERING_IN_RETURN
}


enum InterestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ArtifactRole {
  OFFERING
  WANTING
}
